{
  "version": 1,
  "id": "volumepot",
  "name": "Volume Pot",
  "description": "Simple voltage divider using a logarithmic potentiometer. The wiper taps a fraction of the input signal — turn the knob to attenuate.",
  "tags": ["volume", "attenuator"],
  "category": "circuits",
  "nodes": [
    {
      "id": "vp-in",
      "type": "jack",
      "position": {
        "x": 60,
        "y": 190
      },
      "data": {
        "label": "INPUT",
        "direction": "in"
      }
    },
    {
      "id": "vp-gnd-in",
      "type": "ground",
      "position": {
        "x": 160,
        "y": 390
      },
      "data": {
        "label": "GND"
      }
    },
    {
      "id": "vp-pot",
      "type": "pot",
      "position": {
        "x": 250,
        "y": 190
      },
      "data": {
        "label": "VOLUME",
        "ohms": 100000,
        "position": 0.7,
        "taper": "log"
      }
    },
    {
      "id": "vp-gnd-pot",
      "type": "ground",
      "position": {
        "x": 380,
        "y": 240
      },
      "data": {
        "label": "GND"
      }
    },
    {
      "id": "vp-out",
      "type": "jack",
      "position": {
        "x": 450,
        "y": 270
      },
      "data": {
        "label": "OUTPUT",
        "direction": "out"
      }
    },
    {
      "id": "vp-gnd-out",
      "type": "ground",
      "position": {
        "x": 380,
        "y": 390
      },
      "data": {
        "label": "GND"
      }
    },
    {
      "id": "vp-note-1",
      "type": "stickynote",
      "position": {
        "x": 60,
        "y": 100
      },
      "data": {
        "label": "What does this do?",
        "text": "A volume pot is a voltage divider — it splits the signal between the output and ground. Turn it down and more signal goes to ground instead.",
        "color": "yellow",
        "size": "sm",
        "width": "normal"
      }
    },
    {
      "id": "vp-note-2",
      "type": "stickynote",
      "position": {
        "x": 260,
        "y": 100
      },
      "data": {
        "label": "Log taper",
        "text": "This pot uses a logarithmic taper, which matches how our ears perceive loudness. A linear pot would feel like most of the change happens at one end.",
        "color": "blue",
        "size": "sm",
        "width": "normal"
      }
    }
  ],
  "edges": [
    {
      "id": "vp-e1",
      "source": "vp-in",
      "sourceHandle": "pos",
      "target": "vp-pot",
      "targetHandle": "ccw"
    },
    {
      "id": "vp-e2",
      "source": "vp-in",
      "sourceHandle": "neg",
      "target": "vp-gnd-in",
      "targetHandle": "gnd"
    },
    {
      "id": "vp-e3",
      "source": "vp-pot",
      "sourceHandle": "cw",
      "target": "vp-gnd-pot",
      "targetHandle": "gnd"
    },
    {
      "id": "vp-e4",
      "source": "vp-pot",
      "sourceHandle": "wiper",
      "target": "vp-out",
      "targetHandle": "pos"
    },
    {
      "id": "vp-e5",
      "source": "vp-gnd-out",
      "sourceHandle": "gnd",
      "target": "vp-out",
      "targetHandle": "neg"
    }
  ]
