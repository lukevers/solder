    {
      "id": "gs-note-1",
      "type": "stickynote",
      "position": {
        "x": 920,
        "y": 170
      },
      "data": {
        "label": "What does this do?",
        "text": "An inverting gain stage amplifies your signal. The GAIN pot controls how much louder the output is — from unity (1×) up to 10× amplification.",
        "color": "yellow",
        "size": "sm",
        "width": "normal"
      }
    },
    {
      "id": "gs-note-gain",
      "type": "stickynote",
      "position": {
        "x": 860,
        "y": 530
      },
      "data": {
        "label": "Gain control (GAIN pot)",
        "text": "The GAIN pot is the feedback resistor. Gain = pot / R1. At max, that's 100k / 10k = 10×. Replace with a fixed resistor for a set gain.",
        "color": "blue",
        "size": "sm",
        "width": "normal"
      }
    },
    {
      "id": "gs-note-bias",
      "type": "stickynote",
      "position": {
        "x": 660,
        "y": 110
      },
      "data": {
        "label": "Bias divider (R4 + R5)",
        "text": "Equal resistors split VCC in half (4.5V), centering the signal in the op-amp's linear range. Unequal values would shift the bias point — clipping one half of the waveform harder than the other.",
        "color": "blue",
        "size": "sm",
        "width": "normal"
      }
    },
    {
      "id": "gs-note-bypass",
      "type": "stickynote",
      "position": {
        "x": 340,
        "y": 230
      },
      "data": {
        "label": "Bypass cap (C3)",
        "text": "Holds the bias voltage steady at audio frequencies. Without it, signal leaks into the bias node and causes oscillation. Larger values keep the bias stable at lower frequencies.",
        "color": "blue",
        "size": "sm",
        "width": "normal"
      }
    },
    {
      "id": "gs-note-caps",
      "type": "stickynote",
      "position": {
        "x": 920,
        "y": 270
      },
      "data": {
        "label": "Coupling caps (C1 + C2)",
        "text": "C1 and C2 block DC, passing only the audio signal. Without them the 4.5V bias would leak to the input and output. Smaller values cut more bass — a tone control trick.",
        "color": "yellow",
        "size": "sm",
        "width": "normal"
      }
    },
