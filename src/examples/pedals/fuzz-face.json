    },
    {
      "id": "da795f31-3e76-4ffd-94ed-0b8712eedf60",
      "type": "stickynote",
      "position": {
        "x": 720,
        "y": -30
      },
      "data": {
        "label": "Voltage Divider - Not Always Equal",
        "text": "R2 + R3 in series like this creates a voltage divider. A voltage divider does not require equal values. It only requires two resistors in series with the output taken from the point between them. Equal values just give a 50/50 split.",
        "color": "pink",
        "size": "sm",
        "width": "normal"
      },
      "measured": {
        "width": 160,
        "height": 94
      },
