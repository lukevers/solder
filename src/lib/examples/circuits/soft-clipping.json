{
  "version": 1,
  "id": "softclipping",
  "name": "Soft Clipping",
  "description": "Anti-parallel germanium diodes (1N270) shunt signal to ground after a series resistor. Germanium diodes have a lower forward voltage (~0.3V), producing a gentle, rounded clipping.",
