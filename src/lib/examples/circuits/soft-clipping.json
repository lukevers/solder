      "position": { "x": 400, "y": 440 },
      "data": { "label": "GND" }
    },
    {
      "id": "sc-out",
      "type": "jack",
      "position": { "x": 570, "y": 200 },
      "data": { "label": "OUTPUT", "direction": "out" }
    },
    {
      "id": "sc-gnd-out",
      "type": "ground",
      "position": { "x": 500, "y": 440 },
      "data": { "label": "GND" }
    },
    {
      "id": "sc-note-1",
      "type": "stickynote",
      "position": { "x": 40, "y": 100 },
      "data": {
        "label": "What does this do?",
        "text": "Soft clipping gently rounds off the peaks of your signal, adding warm, mild overdrive. Think blues or light crunch tones.",
        "color": "blue"
      }
    },
    {
      "id": "sc-note-2",
      "type": "stickynote",
      "position": { "x": 270, "y": 100 },
      "data": {
        "label": "Why germanium?",
        "text": "Germanium diodes (1N270) clip at ~0.3V — much lower than silicon. This means they start rounding the signal sooner and more gradually.",
        "color": "green"
      }
    },
    {
      "id": "sc-note-3",
      "type": "stickynote",
      "position": { "x": 500, "y": 100 },
      "data": {
        "label": "Anti-parallel diodes",
        "text": "D1 and D2 face opposite directions. One clips the positive peaks, the other clips the negative peaks — symmetrical clipping.",
        "color": "yellow"
      }
    }
  ],
