    {
      "id": "sc-note-1",
      "type": "stickynote",
      "position": { "x": 40, "y": 280 },
      "data": {
        "label": "What does this do?",
        "text": "Soft clipping gradually rounds off the signal peaks, adding warm, smooth overdrive. The op-amp's feedback loop compresses the signal instead of chopping it flat.",
        "color": "blue"
      }
    },
    {
      "id": "sc-note-2",
      "type": "stickynote",
      "position": { "x": 600, "y": 620 },
      "data": {
        "label": "Feedback diodes",
        "text": "D1 and D2 sit in the feedback loop alongside R2. When the signal is small, R2 sets the gain. As the output grows, the diodes start conducting and gradually reduce the gain — rounding the peaks smoothly.",
        "color": "green"
      }
    },
    {
      "id": "sc-note-3",
      "type": "stickynote",
      "position": { "x": 900, "y": 280 },
      "data": {
        "label": "Same diodes, different result",
        "text": "Compare this to the Hard Clipping example — both use 1N914 silicon diodes! But here they're in the feedback loop (soft), not shunting to ground (hard). Topology matters more than the diode type.",
        "color": "yellow"
      }
    }
  ],
