{
  "version": 1,
  "id": "highpassfilter",
  "name": "High Pass Filter",
  "description": "First-order CR high-pass filter. The series capacitor blocks DC and low frequencies. The CUTOFF pot shunts the signal to ground, controlling how much bass passes through.",
  "tags": ["filter", "basic"],
  "category": "circuits",
  "nodes": [
    {
      "id": "hpf-in",
      "type": "jack",
      "position": { "x": 40, "y": 200 },
      "data": { "label": "INPUT", "direction": "in" }
    },
    {
      "id": "hpf-gnd-in",
      "type": "ground",
      "position": { "x": 110, "y": 430 },
      "data": { "label": "GND" }
    },
    {
      "id": "hpf-cap",
      "type": "capacitor",
      "position": { "x": 180, "y": 200 },
      "data": { "label": "C1", "farads": 4.7e-8 }
    },
    {
      "id": "hpf-jct",
      "type": "junction",
      "position": { "x": 290, "y": 210 },
      "data": { "label": "J1" }
    },
    {
      "id": "hpf-pot",
      "type": "pot",
      "position": { "x": 260, "y": 290 },
      "rotation": 90,
      "data": { "label": "CUTOFF", "ohms": 100000, "position": 0.5, "taper": "linear" }
    },
    {
      "id": "hpf-gnd-pot",
      "type": "ground",
      "position": { "x": 220, "y": 430 },
      "data": { "label": "GND" }
    },
    {
      "id": "hpf-out",
      "type": "jack",
      "position": { "x": 430, "y": 200 },
      "data": { "label": "OUTPUT", "direction": "out" }
    },
    {
      "id": "hpf-gnd-out",
      "type": "ground",
      "position": { "x": 380, "y": 430 },
      "data": { "label": "GND" }
    }
  ],
  "edges": [
    {
      "id": "hpf-e1",
      "source": "hpf-in",
      "sourceHandle": "pos",
      "target": "hpf-cap",
      "targetHandle": "a"
    },
    {
      "id": "hpf-e2",
      "source": "hpf-in",
      "sourceHandle": "neg",
      "target": "hpf-gnd-in",
      "targetHandle": "gnd"
    },
    {
      "id": "hpf-e3",
      "source": "hpf-cap",
      "sourceHandle": "b",
      "target": "hpf-jct",
      "targetHandle": "tl"
    },
    {
      "id": "hpf-e4",
      "source": "hpf-jct",
      "sourceHandle": "sr",
      "target": "hpf-out",
      "targetHandle": "pos"
    },
    {
      "id": "hpf-e5",
      "source": "hpf-jct",
      "sourceHandle": "sb",
      "target": "hpf-pot",
      "targetHandle": "ccw"
    },
    {
      "id": "hpf-e6",
      "source": "hpf-pot",
      "sourceHandle": "wiper",
      "target": "hpf-gnd-pot",
      "targetHandle": "gnd"
    },
    {
      "id": "hpf-e7",
      "source": "hpf-gnd-out",
      "sourceHandle": "gnd",
      "target": "hpf-out",
      "targetHandle": "neg"
    }
  ]
}
