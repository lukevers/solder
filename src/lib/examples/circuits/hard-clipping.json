    {
      "id": "hc-note-1",
      "type": "stickynote",
      "position": { "x": 40, "y": 280 },
      "data": {
        "label": "What does this do?",
        "text": "Hard clipping chops the signal peaks flat, creating aggressive, buzzy distortion. The op-amp amplifies the signal, then shunt diodes brutally clamp it at ±0.7V.",
        "color": "blue"
      }
    },
    {
      "id": "hc-note-2",
      "type": "stickynote",
      "position": { "x": 1070, "y": 620 },
      "data": {
        "label": "Shunt diodes",
        "text": "D1 and D2 connect from the signal path directly to ground. When the amplified signal exceeds ~0.7V, the diodes conduct and dump the excess to ground — creating a hard, flat-topped cutoff.",
        "color": "green"
      }
    },
    {
      "id": "hc-note-3",
      "type": "stickynote",
      "position": { "x": 950, "y": 280 },
      "data": {
        "label": "Same diodes, different result",
        "text": "Compare this to the Soft Clipping example — both use 1N914 silicon diodes! But here they shunt to ground (hard), not in the feedback loop (soft). Topology matters more than the diode type.",
        "color": "yellow"
      }
    }
  ],
