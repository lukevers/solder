{
  "version": 1,
  "id": "lowpassfilter",
  "name": "Low Pass Filter",
  "description": "First-order RC low-pass filter. The CUTOFF pot acts as a variable series resistor — turning it up raises the cutoff frequency, letting more treble through.",
  "tags": ["filter"],
  "category": "circuits",
  "nodes": [
    {
      "id": "lpf-in",
      "type": "jack",
      "position": { "x": 40, "y": 200 },
      "data": { "label": "INPUT", "direction": "in" }
    },
    {
      "id": "lpf-gnd-in",
      "type": "ground",
      "position": { "x": 120, "y": 430 },
      "data": { "label": "GND" }
    },
    {
      "id": "lpf-pot",
      "type": "pot",
      "position": { "x": 220, "y": 200 },
      "data": { "label": "CUTOFF", "ohms": 100000, "position": 0.5, "taper": "linear" }
    },
    {
      "id": "lpf-jct",
      "type": "junction",
      "position": { "x": 248, "y": 290 },
      "data": { "label": "J1" }
    },
    {
      "id": "lpf-cap",
      "type": "capacitor",
      "position": { "x": 240, "y": 340 },
      "rotation": 90,
      "data": { "label": "C1", "farads": 4.7e-8 }
    },
    {
      "id": "lpf-gnd-cap",
      "type": "ground",
      "position": { "x": 240, "y": 430 },
      "data": { "label": "GND" }
    },
    {
      "id": "lpf-out",
      "type": "jack",
      "position": { "x": 440, "y": 280 },
      "data": { "label": "OUTPUT", "direction": "out" }
    },
    {
      "id": "lpf-gnd-out",
      "type": "ground",
      "position": { "x": 380, "y": 430 },
      "data": { "label": "GND" }
    },
    {
      "id": "lpf-note-1",
      "type": "stickynote",
      "position": { "x": 140, "y": 70 },
      "data": {
        "label": "What does this do?",
        "text": "A low-pass filter lets bass and mids through but cuts treble. Like turning the tone knob down on a guitar.",
        "color": "blue"
      }
    },
    {
      "id": "lpf-note-2",
      "type": "stickynote",
      "position": { "x": 320, "y": 70 },
      "data": {
        "label": "How it works",
        "text": "The resistor (pot) and capacitor form a voltage divider. High frequencies see the cap as a short to ground, so they get cut.",
        "color": "green"
      }
    },
    {
      "id": "lpf-note-3",
      "type": "stickynote",
      "position": { "x": 320, "y": 170 },
      "data": {
        "label": "Try it",
        "text": "Turn the CUTOFF pot up to raise the cutoff frequency and let more treble through. Lower values = darker tone.",
        "color": "yellow"
      }
    }
  ],
  "edges": [
    {
      "id": "lpf-e1",
      "source": "lpf-in",
      "sourceHandle": "pos",
      "target": "lpf-pot",
      "targetHandle": "ccw"
    },
    {
      "id": "lpf-e2",
      "source": "lpf-in",
      "sourceHandle": "neg",
      "target": "lpf-gnd-in",
      "targetHandle": "gnd"
    },
    {
      "id": "lpf-e3",
      "source": "lpf-pot",
      "sourceHandle": "wiper",
      "target": "lpf-jct",
      "targetHandle": "tt"
    },
    {
      "id": "lpf-e4",
      "source": "lpf-jct",
      "sourceHandle": "sr",
      "target": "lpf-out",
      "targetHandle": "pos"
    },
    {
      "id": "lpf-e5",
      "source": "lpf-jct",
      "sourceHandle": "sb",
      "target": "lpf-cap",
      "targetHandle": "a"
    },
    {
      "id": "lpf-e6",
      "source": "lpf-cap",
      "sourceHandle": "b",
      "target": "lpf-gnd-cap",
      "targetHandle": "gnd"
    },
    {
      "id": "lpf-e7",
      "source": "lpf-gnd-out",
      "sourceHandle": "gnd",
      "target": "lpf-out",
      "targetHandle": "neg"
    }
  ]
}
